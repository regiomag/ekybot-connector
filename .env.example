# Ekybot API Configuration
EKYBOT_API_KEY=your_api_key_here
EKYBOT_API_URL=https://api.ekybot.com
EKYBOT_WS_URL=wss://api.ekybot.com/ws

# Workspace Configuration  
WORKSPACE_NAME=my-workspace
WORKSPACE_ID=
AGENT_PREFIX=openclaw-

# OpenClaw Configuration
OPENCLAW_CONFIG_PATH=~/.openclaw/config.json
OPENCLAW_AGENTS_PATH=~/.openclaw/agents

# Service Configuration
TELEMETRY_INTERVAL=60000
LOG_LEVEL=info
SERVICE_PORT=3847

# Optional: Custom endpoints for enterprise deployments
# EKYBOT_API_URL=https://your-enterprise-ekybot.com/api
# EKYBOT_WS_URL=wss://your-enterprise-ekybot.com/ws