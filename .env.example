# Ekybot Connector Configuration
# Copy this file to .env and fill in your values

# Required: Your Ekybot API key (get it from https://ekybot.com/settings/api)
EKYBOT_API_KEY=

# Optional: Custom API endpoint (default: https://api.ekybot.com)
# EKYBOT_API_URL=https://api.ekybot.com

# Optional: WebSocket endpoint for real-time streaming
# EKYBOT_WS_URL=wss://api.ekybot.com/ws

# Optional: Telemetry interval in milliseconds (default: 60000 = 1 minute)
# TELEMETRY_INTERVAL=60000

# Optional: Custom OpenClaw config path
# Defaults: ~/.openclaw/openclaw.json, then ~/.openclaw/config.json
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# Optional: Custom agents directory
# OPENCLAW_AGENTS_PATH=~/.openclaw/agents

# Companion inventory-only enrollment
# EKYBOT_APP_URL=https://www.ekybot.com
# EKYBOT_COMPANION_REGISTRATION_TOKEN=ekrt_xxx
# EKYBOT_MACHINE_NAME=my-openclaw-host
# EKYBOT_COMPANION_STATE_PATH=~/.config/ekybot-companion/state.json
